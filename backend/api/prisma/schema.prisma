datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum IdentityMode {
  ANONYMOUS
  AUTHENTICATED
}

enum IdentityState {
  ANONYMOUS
  PENDING_REVEAL
  REVEALED
  VERIFIED
  ORGANIZATION
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
  REMOVED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ActorType {
  USER
  GUEST
  BOT
  SUPPORT
  AI
}

model GuestSession {
  id         String   @id @default(cuid())
  guestToken String   @unique
  deviceId   String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  actors Actor[]

  @@index([expiresAt])
}

model Actor {
  id             String    @id @default(cuid())
  type           ActorType
  userId         String?
  guestSessionId String?

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)

  participants Participant[]
  connectionsInitiated Connection[] @relation("ConnectionActor1")
  connectionsReceived  Connection[] @relation("ConnectionActor2")
  devices              Device[]

  @@index([userId])
  @@index([guestSessionId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  password      String? // Hashed password
  image         String?
  bio           String?
  lastIp        String?
  userAgent     String?
  lastLoginAt   DateTime?

  accounts             Account[]
  sessions             Session[]
  actors               Actor[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Conversation {
  id                 String             @id @default(cuid())
  type               ConversationType   @default(DIRECT)
  policyId           String             @default("policy_anon_stranger_v1")
  name               String?
  status             ConversationStatus @default(ACTIVE)
  lastMessageId      String?
  lastMessagePreview String?
  lastActivityAt     DateTime           @default(now())
  
  policy             Policy             @relation(fields: [policyId], references: [id])
  participants       Participant[]
  messages           Message[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([lastActivityAt])
}

model Participant {
  id             String   @id @default(cuid())
  actorId        String
  conversationId String
  joinedAt       DateTime @default(now())

  // User-specific conversation settings
  identityState     IdentityState @default(ANONYMOUS)
  persona           Persona?
  revealInitiatedAt DateTime?
  revealConfirmedAt DateTime?

  isFavorited Boolean @default(false)
  isPinned    Boolean @default(false)
  isArchived  Boolean @default(false)
  isMuted     Boolean @default(false)
  unreadCount Int     @default(0)
  hasLeft     Boolean @default(false)

  actor        Actor        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([actorId, conversationId])
  @@index([actorId])
  @@index([conversationId])
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
}

model Message {
  id                  String      @id @default(cuid())
  conversationId      String
  senderParticipantId String
  content             String
  contentType         ContentType @default(TEXT)
  clientMessageId     String      @unique @default(cuid())
  replyToId           String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?
  isEdited            Boolean     @default(false)
  metadata            Json? // Used for reactions, edit history, etc.

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Participant  @relation(fields: [senderParticipantId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Connection {
  id        String           @id @default(cuid())
  actor1Id  String
  actor2Id  String
  status    ConnectionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  actor1 Actor @relation("ConnectionActor1", fields: [actor1Id], references: [id], onDelete: Cascade)
  actor2 Actor @relation("ConnectionActor2", fields: [actor2Id], references: [id], onDelete: Cascade)

  @@unique([actor1Id, actor2Id])
}

model DomainEvent {
  id            String    @id @default(cuid())
  eventType     String
  aggregateId   String
  aggregateType String
  payload       Json
  publishedAt   DateTime?
  occurredAt    DateTime  @default(now())

  @@index([publishedAt])
  @@index([occurredAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  event      String
  metadata   Json
  ip         String?
  occurredAt DateTime @default(now())

  @@index([actorId])
  @@index([occurredAt])
}

model Persona {
  id            String      @id @default(cuid())
  participantId String      @unique
  displayName   String      @default("Stranger")
  avatarSeed    String
  color         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model Device {
  id        String   @id @default(cuid())
  actorId   String
  deviceId  String
  platform  String
  pushToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, deviceId])
}

model Policy {
  id          String         @id @default(cuid())
  name        String
  description String?
  rules       Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  conversations Conversation[]
}

