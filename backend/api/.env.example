# Port number for the REST API server
PORT=3002

# PostgreSQL connection string for the database (e.g. Supabase)
DATABASE_URL=postgresql://user:password@host:port/database

# Resend API Key for sending transactional emails (OTP)
RESEND_API_KEY=re_your_api_key

# Sender email header (Defaults to "Moots <noreply@moots.in>" if not set)
# EMAIL_FROM=Moots <noreply@moots.in>
