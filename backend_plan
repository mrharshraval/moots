```typescript
async resolveIdentity(participantId: UUID): Promise<GuestSession | UserProfile> {
  const participant = await this.findById(participantId);
  const actor = await this.actorService.findById(participant.actorId);

  if (actor.type === 'USER' && actor.userId) {
    return this.identityService.resolve(actor.userId, participant.identityState);
  }

  if (actor.type === 'GUEST' && actor.guestSessionId) {
    return this.personaService.getForParticipant(participantId);
  }

  throw new Error(`Unsupported actor configuration: type ${actor.type}`);
}
