## Part V — Shared Contracts Package

Both services must share type definitions and validation schemas. This requires a workspace package.

```
backend/
├── api/
├── realtime/
└── packages/
    └── contracts/
        ├── package.json
        ├── tsconfig.json
        └── src/
            ├── events.ts          # Platform event types and envelopes
            ├── ws-events.ts       # WebSocket client↔server event types
            ├── schemas.ts         # Shared Zod schemas (aligned to zod v4)
            └── index.ts
```

```typescript
// packages/contracts/src/ws-events.ts

// Client → Server (inbound)
export type ClientToServerEvents = {
  'join-queue':    JoinQueuePayload;
  'cancel-queue':  CancelQueuePayload;
  'send-message':  SendMessagePayload;  // realtime delivers; API persists
  'typing':        TypingPayload;
  'read':          ReadPayload;
};

// Server → Client (outbound)
export type ServerToClientEvents = {
  'matched':             MatchedPayload;
  'waiting':             {};
  'message.sent':        MessageSentPayload;
  'message.edited':      MessageEditedPayload;
  'message.deleted':     MessageDeletedPayload;
  'reaction.updated':    ReactionUpdatedPayload;
  'partner.typing':      TypingPayload;
  'partner.read':        ReadPayload;
  'partner.disconnected': PresencePayload;
  'partner.reconnected':  PresencePayload;
  'identity.reveal_initiated': RevealInitiatedPayload;
  'identity.reveal_confirmed': RevealConfirmedPayload;
  'connection.requested': ConnectionRequestedPayload;
  'connection.accepted':  ConnectionAcceptedPayload;
  'error':               ErrorPayload;
};
```

